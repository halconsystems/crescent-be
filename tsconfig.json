{
  "compilerOptions": {
    "strictPropertyInitialization": false,
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "es2017",
    "types": ["node", "jest"],
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true
  },
  "exclude": ["api", "node_modules", "dist", "target"]
}