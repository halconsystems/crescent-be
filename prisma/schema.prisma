generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id      Int    @id @default(autoincrement())
  name    String
  email   String   @unique
  cnic    String   @unique
  irNo    String   @map("ir.no")
  phone   String
}
