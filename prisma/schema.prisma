generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DesignationType {
  GM
  Manager
  Staff
  Technician
}

enum SaleStageCode {
  SALES
  ACCOUNTS
  OPERATIONS
  TECHNICIAN
}

enum StageStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  HELD
  REJECTED
}

enum SaleType {
  CREDIT
  CASH
  CHEQUE
  TRANSFER
}

enum AccountsDecision {
  HOLD
  APPROVED
  REJECTED
  CONTINUE
}

enum TransmissionType {
  AUTO
  MANUAL
}

model Office {
  officeId   Int      @id @default(autoincrement()) @map("OfficeID")
  officeName String   @unique @map("OfficeName")
  isActive   Boolean  @default(true) @map("IsActive")
  createdAt  DateTime @default(now()) @map("CreatedAt")
  updatedAt  DateTime @updatedAt @map("UpdatedAt")

  zones Zone[]

  @@map("Office")
}

model Product {
  productId   Int      @id @default(autoincrement()) @map("ProductID")
  productName String   @unique @map("ProductName")
  isActive    Boolean  @default(true) @map("IsActive")
  createdAt   DateTime @default(now()) @map("CreatedAt")
  updatedAt   DateTime @updatedAt @map("UpdatedAt")

  saleProductDetails        SaleProductDetails[]
  saleOperationsAssignments SaleOperationsAssignment[]

  @@map("Product")
}

model Bank {
  bankId   Int      @id @default(autoincrement()) @map("BankID")
  bankName String   @unique @map("BankName")
  bankCode String?  @unique @map("BankCode")
  isActive Boolean  @default(true) @map("IsActive")
  createdAt DateTime @default(now()) @map("CreatedAt")
  updatedAt DateTime @updatedAt @map("UpdatedAt")

  bankAccounts BankAccount[]

  @@map("Bank")
}

model BankAccount {
  bankAccountId Int      @id @default(autoincrement()) @map("BankAccountID")
  bankId        Int      @map("BankID")
  accountNo     String   @map("AccountNo")
  iban          String?  @unique @map("IBAN")
  branchCode    String?  @map("BranchCode")
  branch        String?  @map("Branch")
  isActive      Boolean  @default(true) @map("IsActive")
  createdAt     DateTime @default(now()) @map("CreatedAt")
  updatedAt     DateTime @updatedAt @map("UpdatedAt")

  bank Bank @relation(fields: [bankId], references: [bankId])

  @@map("BankAccount")
}

model City {
  cityId    Int      @id @default(autoincrement()) @map("CityID")
  cityName  String   @unique @map("CityName")
  isActive  Boolean  @default(true) @map("IsActive")
  createdAt DateTime @default(now()) @map("CreatedAt")
  updatedAt DateTime @updatedAt @map("UpdatedAt")

  vendors Vendor[]

  @@map("City")
}

model Vendor {
  vendorId        Int      @id @default(autoincrement()) @map("VendorID")
  vendorName      String   @unique @map("VendorName")
  cityId          Int?     @map("CityID")
  address         String?  @map("Address")
  emailId         String?  @map("EmailID")
  contactPerson   String?  @map("ContactPerson")
  primaryMobile   String?  @map("PrimaryMobile")
  secondaryMobile String?  @map("SecondaryMobile")
  isActive        Boolean  @default(true) @map("IsActive")
  createdAt       DateTime @default(now()) @map("CreatedAt")
  updatedAt       DateTime @updatedAt @map("UpdatedAt")

  city City? @relation(fields: [cityId], references: [cityId])

  @@map("Vendor")
}

model Permission {
  permissionId   Int      @id @default(autoincrement()) @map("PermissionID")
  permissionCode String   @unique @map("PermissionCode")
  description    String?  @map("Description")
  isActive       Boolean  @default(true) @map("IsActive")
  createdAt      DateTime @default(now()) @map("CreatedAt")
  updatedAt      DateTime @updatedAt @map("UpdatedAt")

  rolePermissions RolePermission[]

  @@map("Permission")
}

model Role {
  roleId      Int      @id @default(autoincrement()) @map("RoleID")
  roleName    String   @unique @map("RoleName")
  description String?  @map("Description")
  isActive    Boolean  @default(true) @map("IsActive")
  createdAt   DateTime @default(now()) @map("CreatedAt")
  updatedAt   DateTime @updatedAt @map("UpdatedAt")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("Role")
}

model RolePermission {
  rolePermissionId Int      @id @default(autoincrement()) @map("RolePermissionID")
  roleId           Int      @map("RoleID")
  permissionId     Int      @map("PermissionID")
  createdAt        DateTime @default(now()) @map("CreatedAt")
  updatedAt        DateTime @updatedAt @map("UpdatedAt")

  role       Role       @relation(fields: [roleId], references: [roleId], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [permissionId], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("RolePermission")
}

model Employee {
  employeeId       Int             @id @default(autoincrement()) @map("EmployeeID")
  userId           Int?            @unique @map("UserID")
  emailId          String?         @unique @map("EmailID")
  primaryMobileNo  String?         @unique @map("PrimaryMobileNo")
  cnic             String          @unique @map("CNIC")
  designation      DesignationType @map("Designation")
  nextOfKin        String?         @map("NextOfKin")
  nextOfKinContact String?         @map("NextOfKinContact")
  isActive         Boolean         @default(true) @map("IsActive")
  createdAt        DateTime        @default(now()) @map("CreatedAt")
  updatedAt        DateTime        @updatedAt @map("UpdatedAt")

  user          AppUser?       @relation(fields: [userId], references: [userId])
  zoneEmployees ZoneEmployee[]

  @@map("Employee")
}

model AppUser {
  userId       Int      @id @default(autoincrement()) @map("UserID")
  email        String   @unique @map("EmailID")
  passwordHash String   @map("PasswordHash")
  dob          DateTime @map("DOB")
  cnic         String   @unique @map("CNIC")
  contactNo    String   @map("ContactNo")
  address      String   @map("Address")
  createdAt    DateTime @default(now()) @map("CreatedAt")
  updatedAt    DateTime @updatedAt @map("UpdatedAt")

  employee Employee?

  userRoles         UserRole[]
  assignedUserRoles UserRole[] @relation("UserRoleAssignedBy")
  refreshTokens     RefreshToken[]

  createdSales               Sale[]                     @relation("SaleCreatedBy")
  accountsReviews            SaleAccountsReview[]       @relation("AccountsReviewedBy")
  operationsAsTechnician     SaleOperationsAssignment[] @relation("AssignedTechnician")
  operationsAssignedBy       SaleOperationsAssignment[] @relation("AssignedByOperations")
  installationsAsInstaller   SaleInstallation[]         @relation("InstalledByTechnician")
  saleStageStatusUpdates     SaleStageStatus[]          @relation("StageStatusUpdatedBy")
  saleAuditLogs              SaleAuditLog[]             @relation("AuditChangedBy")

  @@map("AppUser")
}

model RefreshToken {
  refreshTokenId    Int       @id @default(autoincrement()) @map("RefreshTokenID")
  userId            Int       @map("UserID")
  tokenHash         String    @unique @map("TokenHash")
  issuedAt          DateTime  @default(now()) @map("IssuedAt")
  expiresAt         DateTime  @map("ExpiresAt")
  revokedAt         DateTime? @map("RevokedAt")
  revokedReason     String?   @map("RevokedReason")
  replacedByTokenId Int?      @map("ReplacedByTokenID")
  userAgent         String?   @map("UserAgent")
  ipv4              String?   @map("IPV4")
  ipv6              String?   @map("IPV6")

  user           AppUser        @relation(fields: [userId], references: [userId])
  replacedBy     RefreshToken?  @relation("RefreshTokenReplacement", fields: [replacedByTokenId], references: [refreshTokenId])
  replacedTokens RefreshToken[] @relation("RefreshTokenReplacement")

  @@map("RefreshToken")
}

model UserRole {
  userRoleId       Int      @id @default(autoincrement()) @map("UserRoleID")
  userId           Int      @map("UserID")
  roleId           Int      @map("RoleID")
  assignedAt       DateTime @default(now()) @map("AssignedAt")
  assignedByUserId Int?     @map("AssignedByUserID")
  createdAt        DateTime @default(now()) @map("CreatedAt")
  updatedAt        DateTime @updatedAt @map("UpdatedAt")

  user       AppUser @relation(fields: [userId], references: [userId])
  role       Role    @relation(fields: [roleId], references: [roleId])
  assignedBy AppUser? @relation("UserRoleAssignedBy", fields: [assignedByUserId], references: [userId])

  @@unique([userId, roleId])
  @@map("UserRole")
}

model ClientCategory {
  categoryId   Int      @id @default(autoincrement()) @map("CategoryID")
  categoryName String   @unique @map("CategoryName")
  isActive     Boolean  @default(true) @map("IsActive")
  createdAt    DateTime @default(now()) @map("CreatedAt")
  updatedAt    DateTime @updatedAt @map("UpdatedAt")

  saleClientDetails SaleClientDetails[]

  @@map("ClientCategory")
}

model Package {
  packageId         Int      @id @default(autoincrement()) @map("PackageID")
  packageName       String   @unique @map("PackageName")
  minCharges        Decimal? @map("MinCharges") @db.Decimal(12, 2)
  minRenewalCharges Decimal? @map("MinRenewalCharges") @db.Decimal(12, 2)
  isActive          Boolean  @default(true) @map("IsActive")
  createdAt         DateTime @default(now()) @map("CreatedAt")
  updatedAt         DateTime @updatedAt @map("UpdatedAt")

  saleProductDetails        SaleProductDetails[]
  saleOperationsAssignments SaleOperationsAssignment[]

  @@map("Package")
}

model Zone {
  zoneId    Int      @id @default(autoincrement()) @map("ZoneID")
  officeId  Int      @map("OfficeID")
  zoneName  String   @map("ZoneName")
  isActive  Boolean  @default(true) @map("IsActive")
  createdAt DateTime @default(now()) @map("CreatedAt")
  updatedAt DateTime @updatedAt @map("UpdatedAt")

  office                     Office                     @relation(fields: [officeId], references: [officeId])
  zoneEmployees              ZoneEmployee[]
  saleOperationsAssignments SaleOperationsAssignment[]

  @@unique([officeId, zoneName])
  @@map("Zone")
}

model ZoneEmployee {
  zoneEmployeeId Int      @id @default(autoincrement()) @map("ZoneEmployeeID")
  zoneId         Int      @map("ZoneID")
  employeeId     Int      @map("EmployeeID")
  createdAt      DateTime @default(now()) @map("CreatedAt")
  updatedAt      DateTime @updatedAt @map("UpdatedAt")

  zone     Zone     @relation(fields: [zoneId], references: [zoneId])
  employee Employee @relation(fields: [employeeId], references: [employeeId])

  @@unique([zoneId, employeeId])
  @@map("ZoneEmployee")
}

model Device {
  deviceId   Int      @id @default(autoincrement()) @map("DeviceID")
  deviceName String   @unique @map("DeviceName")
  isActive   Boolean  @default(true) @map("IsActive")
  createdAt  DateTime @default(now()) @map("CreatedAt")
  updatedAt  DateTime @updatedAt @map("UpdatedAt")

  saleOperationsAssignments SaleOperationsAssignment[]

  @@map("Device")
}

model Sim {
  simId     Int      @id @default(autoincrement()) @map("SIMID")
  simName   String   @unique @map("SIMName")
  isActive  Boolean  @default(true) @map("IsActive")
  createdAt DateTime @default(now()) @map("CreatedAt")
  updatedAt DateTime @updatedAt @map("UpdatedAt")

  saleOperationsAssignments SaleOperationsAssignment[]

  @@map("SIM")
}

model DeviceCombo {
  deviceComboId Int      @id @default(autoincrement()) @map("DeviceComboID")
  comboName     String   @unique @map("ComboName")
  isActive      Boolean  @default(true) @map("IsActive")
  createdAt     DateTime @default(now()) @map("CreatedAt")
  updatedAt     DateTime @updatedAt @map("UpdatedAt")

  saleOperationsAssignments SaleOperationsAssignment[]

  @@map("DeviceCombo")
}

model Accessory {
  accessoryId   Int      @id @default(autoincrement()) @map("AccessoryID")
  accessoryName String   @unique @map("AccessoryName")
  isActive      Boolean  @default(true) @map("IsActive")
  createdAt     DateTime @default(now()) @map("CreatedAt")
  updatedAt     DateTime @updatedAt @map("UpdatedAt")

  operationsAsAccessory1 SaleOperationsAssignment[] @relation("Accessory1")
  operationsAsAccessory2 SaleOperationsAssignment[] @relation("Accessory2")
  operationsAsAccessory3 SaleOperationsAssignment[] @relation("Accessory3")

  @@map("Accessory")
}

model Sale {
  saleId          Int      @id @default(autoincrement()) @map("SaleID")
  saleCode        String   @unique @map("SaleCode")
  createdByUserId Int      @map("CreatedByUserID")
  createdAt       DateTime @default(now()) @map("CreatedAt")
  updatedAt       DateTime @updatedAt @map("UpdatedAt")
  isActive        Boolean  @default(true) @map("IsActive")

  createdBy AppUser @relation("SaleCreatedBy", fields: [createdByUserId], references: [userId])

  clientDetails        SaleClientDetails?
  productDetails       SaleProductDetails?
  accountsReview       SaleAccountsReview?
  operationsAssignment SaleOperationsAssignment?
  installation         SaleInstallation?
  stageStatuses        SaleStageStatus[]
  auditLogs            SaleAuditLog[]

  @@map("Sale")
}

model SaleClientDetails {
  saleClientDetailsId Int       @id @default(autoincrement()) @map("SaleClientDetailsID")
  saleId              Int       @unique @map("SaleID")
  clientCategoryId    Int?      @map("ClientCategoryID")
  irNo                String?   @map("IRNo")
  fullName            String?   @map("FullName")
  cnicNo              String?   @map("CNICNo")
  phoneHome           String?   @map("PhoneHome")
  emailId             String?   @map("EmailID")
  address             String?   @map("Address")
  clientStatus        String?   @map("ClientStatus")
  cellNo              String?   @map("CellNo")
  fatherName          String?   @map("FatherName")
  dateOfBirth         DateTime? @map("DateOfBirth")
  phoneOffice         String?   @map("PhoneOffice")
  companyDepartment   String?   @map("CompanyDepartment")
  addressLine2        String?   @map("AddressLine2")

  sale           Sale            @relation(fields: [saleId], references: [saleId], onDelete: Cascade)
  clientCategory ClientCategory? @relation(fields: [clientCategoryId], references: [categoryId])

  @@map("SaleClientDetails")
}

model SaleProductDetails {
  saleProductDetailsId Int       @id @default(autoincrement()) @map("SaleProductDetailsID")
  saleId               Int       @unique @map("SaleID")
  productId            Int?      @map("ProductID")
  saleAmount           Decimal?  @map("SaleAmount") @db.Decimal(12, 2)
  saleType             SaleType? @map("SaleType")
  packageId            Int?      @map("PackageID")
  renewalCharges       Decimal?  @map("RenewalCharges") @db.Decimal(12, 2)
  customTypeValue      Int?      @map("CustomTypeValue")
  salesRemarks         String?   @map("SalesRemarks")

  sale    Sale     @relation(fields: [saleId], references: [saleId], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [productId])
  package Package? @relation(fields: [packageId], references: [packageId])

  @@map("SaleProductDetails")
}

model SaleAccountsReview {
  saleAccountsReviewId Int               @id @default(autoincrement()) @map("SaleAccountsReviewID")
  saleId               Int               @unique @map("SaleID")
  accountsRemark       String?           @map("AccountsRemark")
  decision             AccountsDecision? @map("Decision")
  reviewedByUserId     Int?              @map("ReviewedByUserID")
  reviewedAt           DateTime?         @map("ReviewedAt")

  sale       Sale     @relation(fields: [saleId], references: [saleId], onDelete: Cascade)
  reviewedBy AppUser? @relation("AccountsReviewedBy", fields: [reviewedByUserId], references: [userId])

  @@map("SaleAccountsReview")
}

model SaleOperationsAssignment {
  saleOperationsAssignmentId Int       @id @default(autoincrement()) @map("SaleOperationsAssignmentID")
  saleId                     Int       @unique @map("SaleID")
  productId                  Int?      @map("ProductID")
  zoneId                     Int?      @map("ZoneID")
  deviceComboId              Int?      @map("DeviceComboID")
  simId                      Int?      @map("SIMID")
  accessory1Id               Int?      @map("Accessory1ID")
  accessory2Id               Int?      @map("Accessory2ID")
  accessory3Id               Int?      @map("Accessory3ID")
  packageId                  Int?      @map("PackageID")
  assignedTechnicianUserId   Int?      @map("AssignedTechnicianUserID")
  deviceId                   Int?      @map("DeviceID")
  assignedByUserId           Int?      @map("AssignedByUserID")
  assignedAt                 DateTime? @map("AssignedAt")

  sale                 Sale          @relation(fields: [saleId], references: [saleId], onDelete: Cascade)
  product              Product?      @relation(fields: [productId], references: [productId])
  zone                 Zone?         @relation(fields: [zoneId], references: [zoneId])
  deviceCombo          DeviceCombo?  @relation(fields: [deviceComboId], references: [deviceComboId])
  sim                  Sim?          @relation(fields: [simId], references: [simId])
  accessory1           Accessory?    @relation("Accessory1", fields: [accessory1Id], references: [accessoryId])
  accessory2           Accessory?    @relation("Accessory2", fields: [accessory2Id], references: [accessoryId])
  accessory3           Accessory?    @relation("Accessory3", fields: [accessory3Id], references: [accessoryId])
  package              Package?      @relation(fields: [packageId], references: [packageId])
  assignedTechnician   AppUser?      @relation("AssignedTechnician", fields: [assignedTechnicianUserId], references: [userId])
  device               Device?       @relation(fields: [deviceId], references: [deviceId])
  assignedBy           AppUser?      @relation("AssignedByOperations", fields: [assignedByUserId], references: [userId])

  @@map("SaleOperationsAssignment")
}

model SaleInstallation {
  saleInstallationId Int               @id @default(autoincrement()) @map("SaleInstallationID")
  saleId             Int               @unique @map("SaleID")
  installationDate   DateTime?         @map("InstallationDate")
  renewalDate        DateTime?         @map("RenewalDate")
  registrationNo     String?           @map("RegistrationNo")
  engineNo           String?           @map("EngineNo")
  transmissionType   TransmissionType? @map("TransmissionType")
  chassisNo          String?           @map("ChassisNo")
  makeModel          String?           @map("MakeModel")
  vehicleYear        Int?              @map("VehicleYear")
  color              String?           @map("Color")
  installedByUserId  Int?              @map("InstalledByUserID")
  installedAt        DateTime?         @map("InstalledAt")

  sale        Sale     @relation(fields: [saleId], references: [saleId], onDelete: Cascade)
  installedBy AppUser? @relation("InstalledByTechnician", fields: [installedByUserId], references: [userId])

  @@map("SaleInstallation")
}

model SaleStageStatus {
  saleStageStatusId Int           @id @default(autoincrement()) @map("SaleStageStatusID")
  saleId            Int           @map("SaleID")
  stageCode         SaleStageCode @map("StageCode")
  status            StageStatus   @default(PENDING) @map("Status")
  updatedByUserId   Int?          @map("UpdatedByUserID")
  updatedAt         DateTime      @updatedAt @map("UpdatedAt")

  sale      Sale     @relation(fields: [saleId], references: [saleId], onDelete: Cascade)
  updatedBy AppUser? @relation("StageStatusUpdatedBy", fields: [updatedByUserId], references: [userId])

  @@unique([saleId, stageCode])
  @@map("SaleStageStatus")
}

model SaleAuditLog {
  saleAuditLogId  Int            @id @default(autoincrement()) @map("SaleAuditLogID")
  saleId          Int            @map("SaleID")
  stageCode       SaleStageCode? @map("StageCode")
  fieldName       String         @map("FieldName")
  oldValue        String?        @map("OldValue")
  newValue        String?        @map("NewValue")
  changedByUserId Int            @map("ChangedByUserID")
  changedAt       DateTime       @default(now()) @map("ChangedAt")

  sale      Sale    @relation(fields: [saleId], references: [saleId], onDelete: Cascade)
  changedBy AppUser @relation("AuditChangedBy", fields: [changedByUserId], references: [userId])

  @@map("SaleAuditLog")
}

enum InvApprovalStatus {
  DRAFT
  APPROVED
  REJECTED
}

enum InvGrnStatus {
  DRAFT
  CONFIRMED
}

enum InvMovementType {
  GRN_IN
  ISSUANCE_OUT
  RETURN_IN
  TRANSFER_OUT
  TRANSFER_IN
}

model InvStore {
  storeId      Int      @id @default(autoincrement()) @map("StoreID")
  storeName    String   @unique @map("StoreName")
  location     String?  @map("Location")
  isActive     Boolean  @default(true) @map("IsActive")
  createdAt    DateTime @default(now()) @map("CreatedAt")
  updatedAt    DateTime @updatedAt @map("UpdatedAt")

  itemsToStore  InvItem[]
  prHeaders     InvPurchaseRequest[]
  poHeaders     InvPurchaseOrder[]
  grnHeaders    InvGrn[]
  issuanceHeads InvIssuance[]
  returnHeads   InvReturn[]
  transferFroms InvTransfer[] @relation("InvTransferFromStore")
  transferTos   InvTransfer[] @relation("InvTransferToStore")
  ledgerRows    InvStockLedger[]

  @@map("InvStore")
}

model InvCategory {
  categoryId   Int      @id @default(autoincrement()) @map("CategoryID")
  categoryName String   @unique @map("CategoryName")
  isActive     Boolean  @default(true) @map("IsActive")
  createdAt    DateTime @default(now()) @map("CreatedAt")
  updatedAt    DateTime @updatedAt @map("UpdatedAt")

  items InvItem[]

  @@map("InvCategory")
}

model InvGroup {
  groupId      Int      @id @default(autoincrement()) @map("GroupID")
  groupName    String   @unique @map("GroupName")
  description  String?  @map("Description")
  isActive     Boolean  @default(true) @map("IsActive")
  createdAt    DateTime @default(now()) @map("CreatedAt")
  updatedAt    DateTime @updatedAt @map("UpdatedAt")

  items InvItem[]

  @@map("InvGroup")
}

model InvVendor {
  vendorId      Int      @id @default(autoincrement()) @map("VendorID")
  vendorName    String   @unique @map("VendorName")
  contactPerson String?  @map("ContactPerson")
  phone         String?  @map("Phone")
  email         String?  @map("Email")
  address       String?  @map("Address")
  isActive      Boolean  @default(true) @map("IsActive")
  createdAt     DateTime @default(now()) @map("CreatedAt")
  updatedAt     DateTime @updatedAt @map("UpdatedAt")

  purchaseOrders InvPurchaseOrder[]

  @@map("InvVendor")
}

model InvItem {
  itemId         Int      @id @default(autoincrement()) @map("ItemID")
  sku            String   @unique @map("SKU")
  itemName       String   @map("ItemName")
  categoryId     Int?     @map("CategoryID")
  groupId        Int?     @map("GroupID")
  defaultStoreId Int?     @map("DefaultStoreID")
  uom            String?  @map("UOM")
  reorderLevel   Int      @default(0) @map("ReorderLevel")
  isActive       Boolean  @default(true) @map("IsActive")
  createdAt      DateTime @default(now()) @map("CreatedAt")
  updatedAt      DateTime @updatedAt @map("UpdatedAt")

  category     InvCategory? @relation(fields: [categoryId], references: [categoryId])
  group        InvGroup?    @relation(fields: [groupId], references: [groupId])
  defaultStore InvStore?    @relation(fields: [defaultStoreId], references: [storeId])

  prLines       InvPurchaseRequestLine[]
  poLines       InvPurchaseOrderLine[]
  grnLines      InvGrnLine[]
  issuanceLines InvIssuanceLine[]
  returnLines   InvReturnLine[]
  transferLines InvTransferLine[] @relation("InvTransferOutItem")
  ledgerRows    InvStockLedger[]

  @@index([itemName])
  @@index([categoryId])
  @@index([defaultStoreId])
  @@map("InvItem")
}

model InvPurchaseRequest {
  purchaseRequestId Int               @id @default(autoincrement()) @map("PurchaseRequestID")
  requestNo         String            @unique @map("RequestNo")
  storeId           Int?              @map("StoreID")
  status            InvApprovalStatus @default(DRAFT) @map("Status")
  remarks           String?           @map("Remarks")
  requestedByUserId Int?              @map("RequestedByUserID")
  approvedByUserId  Int?              @map("ApprovedByUserID")
  approvedAt        DateTime?         @map("ApprovedAt")
  rejectedByUserId  Int?              @map("RejectedByUserID")
  rejectedAt        DateTime?         @map("RejectedAt")
  rejectionReason   String?           @map("RejectionReason")
  createdAt         DateTime          @default(now()) @map("CreatedAt")
  updatedAt         DateTime          @updatedAt @map("UpdatedAt")

  store InvStore? @relation(fields: [storeId], references: [storeId])
  lines InvPurchaseRequestLine[]
  purchaseOrders InvPurchaseOrder[]

  @@index([status])
  @@index([createdAt])
  @@map("InvPurchaseRequest")
}

model InvPurchaseRequestLine {
  purchaseRequestLineId Int      @id @default(autoincrement()) @map("PurchaseRequestLineID")
  purchaseRequestId     Int      @map("PurchaseRequestID")
  itemId                Int      @map("ItemID")
  qty                   Int      @map("Qty")
  note                  String?  @map("Note")
  createdAt             DateTime @default(now()) @map("CreatedAt")
  updatedAt             DateTime @updatedAt @map("UpdatedAt")

  purchaseRequest InvPurchaseRequest @relation(fields: [purchaseRequestId], references: [purchaseRequestId], onDelete: Cascade)
  item            InvItem            @relation(fields: [itemId], references: [itemId])

  @@index([itemId])
  @@map("InvPurchaseRequestLine")
}

model InvPurchaseOrder {
  purchaseOrderId    Int               @id @default(autoincrement()) @map("PurchaseOrderID")
  poNo               String            @unique @map("PONo")
  purchaseRequestId  Int?              @map("PurchaseRequestID")
  vendorId           Int?              @map("VendorID")
  storeId            Int?              @map("StoreID")
  status             InvApprovalStatus @default(DRAFT) @map("Status")
  orderedByUserId    Int?              @map("OrderedByUserID")
  approvedByUserId   Int?              @map("ApprovedByUserID")
  approvedAt         DateTime?         @map("ApprovedAt")
  rejectedByUserId   Int?              @map("RejectedByUserID")
  rejectedAt         DateTime?         @map("RejectedAt")
  rejectionReason    String?           @map("RejectionReason")
  remarks            String?           @map("Remarks")
  createdAt          DateTime          @default(now()) @map("CreatedAt")
  updatedAt          DateTime          @updatedAt @map("UpdatedAt")

  purchaseRequest InvPurchaseRequest?   @relation(fields: [purchaseRequestId], references: [purchaseRequestId])
  vendor          InvVendor?            @relation(fields: [vendorId], references: [vendorId])
  store           InvStore?             @relation(fields: [storeId], references: [storeId])
  lines           InvPurchaseOrderLine[]
  grns            InvGrn[]

  @@index([status])
  @@index([createdAt])
  @@map("InvPurchaseOrder")
}

model InvPurchaseOrderLine {
  purchaseOrderLineId Int      @id @default(autoincrement()) @map("PurchaseOrderLineID")
  purchaseOrderId     Int      @map("PurchaseOrderID")
  itemId              Int      @map("ItemID")
  qty                 Int      @map("Qty")
  unitPrice           Decimal? @map("UnitPrice") @db.Decimal(12, 2)
  note                String?  @map("Note")
  createdAt           DateTime @default(now()) @map("CreatedAt")
  updatedAt           DateTime @updatedAt @map("UpdatedAt")

  purchaseOrder InvPurchaseOrder @relation(fields: [purchaseOrderId], references: [purchaseOrderId], onDelete: Cascade)
  item          InvItem          @relation(fields: [itemId], references: [itemId])

  @@index([itemId])
  @@map("InvPurchaseOrderLine")
}

model InvGrn {
  grnId              Int          @id @default(autoincrement()) @map("GRNID")
  grnNo              String       @unique @map("GRNNo")
  purchaseOrderId    Int?         @map("PurchaseOrderID")
  storeId            Int?         @map("StoreID")
  status             InvGrnStatus @default(DRAFT) @map("Status")
  receivedByUserId   Int?         @map("ReceivedByUserID")
  confirmedByUserId  Int?         @map("ConfirmedByUserID")
  confirmedAt        DateTime?    @map("ConfirmedAt")
  remarks            String?      @map("Remarks")
  createdAt          DateTime     @default(now()) @map("CreatedAt")
  updatedAt          DateTime     @updatedAt @map("UpdatedAt")

  purchaseOrder InvPurchaseOrder? @relation(fields: [purchaseOrderId], references: [purchaseOrderId])
  store         InvStore?         @relation(fields: [storeId], references: [storeId])
  lines         InvGrnLine[]

  @@index([status])
  @@index([createdAt])
  @@map("InvGRN")
}

model InvGrnLine {
  grnLineId   Int      @id @default(autoincrement()) @map("GRNLineID")
  grnId       Int      @map("GRNID")
  itemId      Int      @map("ItemID")
  qtyReceived Int      @map("QtyReceived")
  note        String?  @map("Note")
  createdAt   DateTime @default(now()) @map("CreatedAt")
  updatedAt   DateTime @updatedAt @map("UpdatedAt")

  grn  InvGrn  @relation(fields: [grnId], references: [grnId], onDelete: Cascade)
  item InvItem @relation(fields: [itemId], references: [itemId])

  @@index([itemId])
  @@map("InvGRNLine")
}

model InvIssuance {
  issuanceId    Int      @id @default(autoincrement()) @map("IssuanceID")
  issuanceNo    String   @unique @map("IssuanceNo")
  storeId       Int      @map("StoreID")
  issuedTo      String?  @map("IssuedTo")
  remarks       String?  @map("Remarks")
  issuedByUserId Int?    @map("IssuedByUserID")
  createdAt     DateTime @default(now()) @map("CreatedAt")
  updatedAt     DateTime @updatedAt @map("UpdatedAt")

  store InvStore @relation(fields: [storeId], references: [storeId])
  lines InvIssuanceLine[]

  @@index([createdAt])
  @@map("InvIssuance")
}

model InvIssuanceLine {
  issuanceLineId Int      @id @default(autoincrement()) @map("IssuanceLineID")
  issuanceId     Int      @map("IssuanceID")
  itemId         Int      @map("ItemID")
  qty            Int      @map("Qty")
  note           String?  @map("Note")
  createdAt      DateTime @default(now()) @map("CreatedAt")
  updatedAt      DateTime @updatedAt @map("UpdatedAt")

  issuance InvIssuance @relation(fields: [issuanceId], references: [issuanceId], onDelete: Cascade)
  item     InvItem     @relation(fields: [itemId], references: [itemId])

  @@index([itemId])
  @@map("InvIssuanceLine")
}

model InvReturn {
  returnId        Int      @id @default(autoincrement()) @map("ReturnID")
  returnNo        String   @unique @map("ReturnNo")
  storeId         Int      @map("StoreID")
  sourceReference String?  @map("SourceReference")
  remarks         String?  @map("Remarks")
  returnedByUserId Int?    @map("ReturnedByUserID")
  createdAt       DateTime @default(now()) @map("CreatedAt")
  updatedAt       DateTime @updatedAt @map("UpdatedAt")

  store InvStore @relation(fields: [storeId], references: [storeId])
  lines InvReturnLine[]

  @@index([createdAt])
  @@map("InvReturn")
}

model InvReturnLine {
  returnLineId Int      @id @default(autoincrement()) @map("ReturnLineID")
  returnId     Int      @map("ReturnID")
  itemId       Int      @map("ItemID")
  qty          Int      @map("Qty")
  note         String?  @map("Note")
  createdAt    DateTime @default(now()) @map("CreatedAt")
  updatedAt    DateTime @updatedAt @map("UpdatedAt")

  return InvReturn @relation(fields: [returnId], references: [returnId], onDelete: Cascade)
  item   InvItem   @relation(fields: [itemId], references: [itemId])

  @@index([itemId])
  @@map("InvReturnLine")
}

model InvTransfer {
  transferId     Int      @id @default(autoincrement()) @map("TransferID")
  transferNo     String   @unique @map("TransferNo")
  fromStoreId    Int      @map("FromStoreID")
  toStoreId      Int      @map("ToStoreID")
  remarks        String?  @map("Remarks")
  transferredByUserId Int? @map("TransferredByUserID")
  createdAt      DateTime @default(now()) @map("CreatedAt")
  updatedAt      DateTime @updatedAt @map("UpdatedAt")

  fromStore InvStore @relation("InvTransferFromStore", fields: [fromStoreId], references: [storeId])
  toStore   InvStore @relation("InvTransferToStore", fields: [toStoreId], references: [storeId])
  lines     InvTransferLine[]

  @@index([createdAt])
  @@map("InvTransfer")
}

model InvTransferLine {
  transferLineId Int      @id @default(autoincrement()) @map("TransferLineID")
  transferId     Int      @map("TransferID")
  itemId         Int      @map("ItemID")
  qty            Int      @map("Qty")
  note           String?  @map("Note")
  createdAt      DateTime @default(now()) @map("CreatedAt")
  updatedAt      DateTime @updatedAt @map("UpdatedAt")

  transfer InvTransfer @relation(fields: [transferId], references: [transferId], onDelete: Cascade)
  item     InvItem     @relation("InvTransferOutItem", fields: [itemId], references: [itemId])

  @@index([itemId])
  @@map("InvTransferLine")
}

model InvStockLedger {
  stockLedgerId  Int             @id @default(autoincrement()) @map("StockLedgerID")
  movementType   InvMovementType @map("MovementType")
  itemId         Int             @map("ItemID")
  storeId        Int             @map("StoreID")
  qtyIn          Int             @default(0) @map("QtyIn")
  qtyOut         Int             @default(0) @map("QtyOut")
  movementDate   DateTime        @default(now()) @map("MovementDate")
  referenceType  String          @map("ReferenceType")
  referenceId    Int             @map("ReferenceID")
  remarks        String?         @map("Remarks")
  createdAt      DateTime        @default(now()) @map("CreatedAt")

  item  InvItem  @relation(fields: [itemId], references: [itemId])
  store InvStore @relation(fields: [storeId], references: [storeId])

  @@index([itemId, storeId, movementDate])
  @@index([referenceType, referenceId])
  @@map("InvStockLedger")
}
