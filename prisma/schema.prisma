generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DesignationType {
  GM
  Manager
  Staff
  Technician
}

model Office {
  officeId   Int      @id @default(autoincrement()) @map("OfficeID")
  officeName String   @unique @map("OfficeName")
  isActive   Boolean  @default(true) @map("IsActive")
  createdAt  DateTime @default(now()) @map("CreatedAt")
  updatedAt  DateTime @updatedAt @map("UpdatedAt")

  zones Zone[]

  @@map("Office")
}

model Product {
  productId   Int      @id @default(autoincrement()) @map("ProductID")
  productName String   @unique @map("ProductName")
  isActive    Boolean  @default(true) @map("IsActive")
  createdAt   DateTime @default(now()) @map("CreatedAt")
  updatedAt   DateTime @updatedAt @map("UpdatedAt")

  @@map("Product")
}

model Bank {
  bankId   Int      @id @default(autoincrement()) @map("BankID")
  bankName String   @unique @map("BankName")
  bankCode String?  @unique @map("BankCode")
  isActive Boolean  @default(true) @map("IsActive")
  createdAt DateTime @default(now()) @map("CreatedAt")
  updatedAt DateTime @updatedAt @map("UpdatedAt")

  bankAccounts BankAccount[]

  @@map("Bank")
}

model BankAccount {
  bankAccountId Int      @id @default(autoincrement()) @map("BankAccountID")
  bankId        Int      @map("BankID")
  accountNo     String   @map("AccountNo")
  iban          String?  @unique @map("IBAN")
  branchCode    String?  @map("BranchCode")
  branch        String?  @map("Branch")
  isActive      Boolean  @default(true) @map("IsActive")
  createdAt     DateTime @default(now()) @map("CreatedAt")
  updatedAt     DateTime @updatedAt @map("UpdatedAt")

  bank Bank @relation(fields: [bankId], references: [bankId])

  @@map("BankAccount")
}

model City {
  cityId   Int      @id @default(autoincrement()) @map("CityID")
  cityName String   @unique @map("CityName")
  isActive Boolean  @default(true) @map("IsActive")
  createdAt DateTime @default(now()) @map("CreatedAt")
  updatedAt DateTime @updatedAt @map("UpdatedAt")

  vendors Vendor[]

  @@map("City")
}

model Vendor {
  vendorId        Int      @id @default(autoincrement()) @map("VendorID")
  vendorName      String   @unique @map("VendorName")
  cityId          Int?     @map("CityID")
  address         String?  @map("Address")
  emailId         String?  @map("EmailID")
  contactPerson   String?  @map("ContactPerson")
  primaryMobile   String?  @map("PrimaryMobile")
  secondaryMobile String?  @map("SecondaryMobile")
  isActive        Boolean  @default(true) @map("IsActive")
  createdAt       DateTime @default(now()) @map("CreatedAt")
  updatedAt       DateTime @updatedAt @map("UpdatedAt")

  city City? @relation(fields: [cityId], references: [cityId])

  @@map("Vendor")
}

model Role {
  roleId      Int      @id @default(autoincrement()) @map("RoleID")
  roleName    String   @unique @map("RoleName")
  description String?  @map("Description")
  isActive    Boolean  @default(true) @map("IsActive")
  createdAt   DateTime @default(now()) @map("CreatedAt")
  updatedAt   DateTime @updatedAt @map("UpdatedAt")

  userRoles UserRole[]

  @@map("Role")
}

model Employee {
  employeeId        Int              @id @default(autoincrement()) @map("EmployeeID")
  emailId           String?          @unique @map("EmailID")
  primaryMobileNo   String?          @unique @map("PrimaryMobileNo")
  cnic              String           @unique @map("CNIC")
  designation       DesignationType  @map("Designation")
  nextOfKin         String?          @map("NextOfKin")
  nextOfKinContact  String?          @map("NextOfKinContact")
  isActive          Boolean          @default(true) @map("IsActive")
  createdAt         DateTime         @default(now()) @map("CreatedAt")
  updatedAt         DateTime         @updatedAt @map("UpdatedAt")

  zoneEmployees ZoneEmployee[]

  @@map("Employee")
}

model AppUser {
  userId               Int       @id @default(autoincrement()) @map("UserID")
  email                String    @unique @map("EmailID")
  passwordHash         String    @map("PasswordHash")
  dob                  DateTime  @map("DOB")
  cnic                 String    @unique @map("CNIC")
  contactNo            String    @map("ContactNo")
  address              String    @map("Address")
  createdAt            DateTime  @default(now()) @map("CreatedAt")
  updatedAt            DateTime  @updatedAt @map("UpdatedAt")

  userRoles           UserRole[]
  assignedUserRoles   UserRole[]           @relation("UserRoleAssignedBy")
  refreshTokens        RefreshToken[]

  @@map("AppUser")
}

model RefreshToken {
  refreshTokenId   Int       @id @default(autoincrement()) @map("RefreshTokenID")
  userId           Int       @map("UserID")
  tokenHash        String    @unique @map("TokenHash")
  issuedAt         DateTime  @default(now()) @map("IssuedAt")
  expiresAt        DateTime  @map("ExpiresAt")
  revokedAt        DateTime? @map("RevokedAt")
  revokedReason    String?   @map("RevokedReason")
  replacedByTokenId Int?     @map("ReplacedByTokenID")
  userAgent        String?   @map("UserAgent")
  ipv4             String?   @map("IPV4")
  ipv6             String?   @map("IPV6")

  user           AppUser       @relation(fields: [userId], references: [userId])
  replacedBy     RefreshToken? @relation("RefreshTokenReplacement", fields: [replacedByTokenId], references: [refreshTokenId])
  replacedTokens RefreshToken[] @relation("RefreshTokenReplacement")

  @@map("RefreshToken")
}

model UserRole {
  userRoleId        Int      @id @default(autoincrement()) @map("UserRoleID")
  userId            Int      @map("UserID")
  roleId            Int      @map("RoleID")
  assignedAt        DateTime @default(now()) @map("AssignedAt")
  assignedByUserId  Int?     @map("AssignedByUserID")
  createdAt         DateTime @default(now()) @map("CreatedAt")
  updatedAt         DateTime @updatedAt @map("UpdatedAt")

  user       AppUser @relation(fields: [userId], references: [userId])
  role       Role    @relation(fields: [roleId], references: [roleId])
  assignedBy AppUser? @relation("UserRoleAssignedBy", fields: [assignedByUserId], references: [userId])

  @@unique([userId, roleId])
  @@map("UserRole")
}

model ClientCategory {
  categoryId   Int      @id @default(autoincrement()) @map("CategoryID")
  categoryName String   @unique @map("CategoryName")
  isActive     Boolean  @default(true) @map("IsActive")
  createdAt    DateTime @default(now()) @map("CreatedAt")
  updatedAt    DateTime @updatedAt @map("UpdatedAt")

  @@map("ClientCategory")
}

model Package {
  packageId         Int      @id @default(autoincrement()) @map("PackageID")
  packageName       String   @unique @map("PackageName")
  minCharges        Decimal? @map("MinCharges") @db.Decimal(12, 2)
  minRenewalCharges Decimal? @map("MinRenewalCharges") @db.Decimal(12, 2)
  isActive          Boolean  @default(true) @map("IsActive")
  createdAt         DateTime @default(now()) @map("CreatedAt")
  updatedAt         DateTime @updatedAt @map("UpdatedAt")

  @@map("Package")
}

model Zone {
  zoneId    Int      @id @default(autoincrement()) @map("ZoneID")
  officeId  Int      @map("OfficeID")
  zoneName  String   @map("ZoneName")
  isActive  Boolean  @default(true) @map("IsActive")
  createdAt DateTime @default(now()) @map("CreatedAt")
  updatedAt DateTime @updatedAt @map("UpdatedAt")

  office        Office         @relation(fields: [officeId], references: [officeId])
  zoneEmployees ZoneEmployee[]

  @@unique([officeId, zoneName])
  @@map("Zone")
}

model ZoneEmployee {
  zoneEmployeeId Int      @id @default(autoincrement()) @map("ZoneEmployeeID")
  zoneId         Int      @map("ZoneID")
  employeeId     Int      @map("EmployeeID")
  createdAt      DateTime @default(now()) @map("CreatedAt")
  updatedAt      DateTime @updatedAt @map("UpdatedAt")

  zone     Zone     @relation(fields: [zoneId], references: [zoneId])
  employee Employee @relation(fields: [employeeId], references: [employeeId])

  @@unique([zoneId, employeeId])
  @@map("ZoneEmployee")
}

model Client {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
  cnic  String @unique
  irNo  String @map("ir.no")
  phone String
}
