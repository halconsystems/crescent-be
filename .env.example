# Allow both frontend ports for CORS
CORS_ORIGIN=
FRONTEND_URL=

# PostgreSQL — set these, then DATABASE_URL (below) must match.
# DB_HOST:
#   - Use `localhost` (or 127.0.0.1) when you run Nest on the host: `npm run start:dev`
#   - Use `db` when the app runs inside Docker Compose (the `app` service); that name is the DB service hostname on the compose network.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# Prisma reads this. If your shell/dotenv does not expand ${...}, set the full URL on one line instead.
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"
